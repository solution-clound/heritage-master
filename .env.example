# 非遗大师助手 - 环境变量配置
# 复制此文件为 .env 并填入你的配置

# ─── 高德地图 API ─────────────────────────────────────
# 申请地址：https://lbs.amap.com/dev/key/app
# 免费额度：每天 5000 次请求
HERITAGE_AMAP_KEY=your_amap_key_here

# ─── GitHub 论坛 ──────────────────────────────────────
# GitHub Personal Access Token（需要 repo 权限）
# 申请地址：https://github.com/settings/tokens
HERITAGE_GITHUB_TOKEN=your_github_token_here

# 论坛仓库（格式：owner/repo）
# 需要先在 GitHub 上创建一个启用 Discussions 的仓库
HERITAGE_FORUM_REPO=your-org/heritage-forum

# ─── RAG 知识库（可选）────────────────────────────────
# 是否启用 RAG 向量检索（需要安装 rag 依赖）
HERITAGE_RAG_ENABLED=false

# ChromaDB 存储路径
HERITAGE_CHROMA_PATH=./heritage_chroma_db

# 向量化模型（首次使用会自动下载）
HERITAGE_EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# ─── 爬虫配置 ─────────────────────────────────────────
# 缓存过期时间（秒），默认 2592000（30天）
HERITAGE_CRAWLER_CACHE_TTL=2592000

# 缓存目录
HERITAGE_CRAWLER_CACHE_DIR=./heritage_cache
